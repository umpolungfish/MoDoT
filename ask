#!/usr/bin/env bash
# MoDoT native ask — full-length questions, --file, interactive, Gemini-class answers.
# Drop-in replacement for: python3 momonados_agent.py --ask / --file / -i
# No Python.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
BIN="$HERE/ask_native/target/release/ask"
if [[ ! -x "$BIN" ]]; then
  echo "[ask] building native binary…" >&2
  cargo build --release --manifest-path "$HERE/ask_native/Cargo.toml"
fi
# Catalog: prefer the canonical imscribing_grammar/IG_catalog.json (the one
# source of truth); mOMonadOS/IG_catalog.json is a stale, smaller, unsynced
# copy (5264 vs 5275+live-merge 5292 entries as of 2026-07-10).
if [[ -z "${MOMONADOS_CATALOG:-}" ]]; then
  if [[ -f "$HERE/../imscribing_grammar/IG_catalog.json" ]]; then
    export MOMONADOS_CATALOG="$HERE/../imscribing_grammar/IG_catalog.json"
  elif [[ -f "$HERE/../mOMonadOS/IG_catalog.json" ]]; then
    export MOMONADOS_CATALOG="$HERE/../mOMonadOS/IG_catalog.json"
  elif [[ -f "$HERE/IG_catalog.json" ]]; then
    export MOMONADOS_CATALOG="$HERE/IG_catalog.json"
  fi
fi
exec "$BIN" "$@"
